# Example configuration for claude-statusline.
# claude-statusline-project: fabifont/claude-statusline
# Keep the marker line above. If it is removed, setup treats this as a non-project config and overwrites it.
#
# Preview before configuring Claude Code:
#   claude-statusline --preview
#   claude-statusline --preview validate
#   claude-statusline --preview sample

separator = " | "
timezone = "Europe/Rome"
colors_enabled = true

[peak_hours]
# 24-hour clock values from 0 to 23.
start_hour = 13
end_hour = 19

[[items]]
# Supported kinds: five_hour, seven_day, limits_age, context, peak, model, cost, command
kind = "five_hour"
label = "5h"
color = "cyan"

[[items]]
kind = "seven_day"
label = "7d"
color = "blue"

# Optional: show age of cached fallback limits when stdin lacks rate_limits.
#[[items]]
#kind = "limits_age"
#label = "cached"
#color = "bright_black"

[[items]]
kind = "context"
label = "ctx"
color = "magenta"

[[items]]
# Renders remaining time while in-window, otherwise shows next start time.
kind = "peak"
label = "🔥"
color = "red"

[[items]]
kind = "model"
color = "green"

[[items]]
kind = "cost"
label = "$"
color = "yellow"

# Optional: external command item (scripts in any language).
# Command is executed directly (no shell unless you explicitly call one).
# Stdout is trimmed/collapsed and rendered as this segment.
#[[items]]
#kind = "command"
#command = "sh"
#args = ["-c", "test -f \"$HOME/.claude/.caveman-active\" && printf '\\033[38;5;172m[CAVEMAN]\\033[0m'"]
#timeout_ms = 120
